<odoo>
    <record id="view_recruitment_blacklist_reason_tree" model="ir.ui.view">
        <field name="name">recruitment.blacklist.reason.tree</field>
        <field name="model">recruitment.blacklist.reason</field>
        <field name="arch" type="xml">
            <tree string="Blacklist Reason List" editable="bottom">
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_recruitment_blacklist_reason_form" model="ir.ui.view">
        <field name="name">recruitment.blacklist.reason.form</field>
        <field name="model">recruitment.blacklist.reason</field>
        <field name="arch" type="xml">
            <form string="Blacklist Reason">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_recruitment_blacklist_reason" model="ir.actions.act_window">
        <field name="name">Blacklist Reasons</field>
        <field name="res_model">recruitment.blacklist.reason</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="menu_recruitment_blacklist_reason" model="ir.ui.menu">
        <field name="name">Blacklist Reasons</field>
        <field name="parent_id" ref="menu_recruitment_candidate_blacklist"/>
        <field name="action" ref="action_recruitment_blacklist_reason"/>
        <field name="sequence">20</field>
        <field name="active" eval="False"/>
    </record>
</odoo>