<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_package_form" model="ir.ui.view">
        <field name="name">asset.package.form</field>
        <field name="model">asset.package</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="VD: Gói Standard Khối Back-Office"/></h1>
                    </div>
                    <group>
                        <field name="max_budget"/>
                    </group>
                    <notebook>
                        <page string="Danh sách tài sản cấp phát">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="is_mandatory" widget="boolean_toggle"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Ghi chú">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asset_package" model="ir.actions.act_window">
        <field name="name">Gói Tài Sản Onboarding</field>
        <field name="res_model">asset.package</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_asset_package" name="Gói Tài Sản" parent="hr.menu_human_resources_configuration" action="action_asset_package" sequence="100"/>
</odoo>