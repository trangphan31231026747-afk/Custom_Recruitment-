<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_check_overdue_applicants" model="ir.cron">
        <field name="name">Check Overdue Applicants</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_overdue_applicants()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_create_overdue_activities" model="ir.cron">
        <field name="name">Create Overdue Applicant Activities</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="state">code</field>
        <field name="code">model.cron_create_overdue_activities()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>