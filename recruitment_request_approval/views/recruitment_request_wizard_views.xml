<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="send_to_ceo_wizard_view_form" model="ir.ui.view">
        <field name="name">send.to.ceo.wizard.form</field>
        <field name="model">send.to.ceo.wizard</field>
        <field name="arch" type="xml">
            <form string="Send to CEO">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="budget_amount"/>
                    <field name="budget_note"/>
                </group>
                <footer>
                    <button name="action_confirm_send_to_ceo" type="object" string="Send to CEO" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="ceo_reject_wizard_view_form" model="ir.ui.view">
        <field name="name">ceo.reject.wizard.form</field>
        <field name="model">ceo.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Request">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="ceo_reject_reason"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hr_feedback_wizard_view_form" model="ir.ui.view">
        <field name="name">hr.feedback.wizard.form</field>
        <field name="model">hr.feedback.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Feedback">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="hr_feedback"/>
                </group>
                <footer>
                    <button name="action_confirm_feedback" type="object" string="Send Feedback" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>