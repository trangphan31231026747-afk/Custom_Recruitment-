<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="menu_recruitment_request_root"
              name="Recruitment Requests"
              parent="hr_recruitment.menu_hr_recruitment_root"
              sequence="5"/>

    <record id="action_department_recruitment_requests" model="ir.actions.act_window">
        <field name="name">Department Recruitment Requests</field>
        <field name="res_model">recruitment.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('hm_id', '=', uid)]</field>
    </record>

    <menuitem id="menu_department_recruitment_requests"
              name="Department Recruitment Requests"
              parent="menu_recruitment_request_root"
              action="action_department_recruitment_requests"
              sequence="1"/>

    <record id="action_hr_review_requests" model="ir.actions.act_window">
        <field name="name">HR Review Requests</field>
        <field name="res_model">recruitment.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['sent_hr', 'need_revision', 'sent_ceo', 'approved', 'rejected'])]</field>
    </record>

    <menuitem id="menu_hr_review_requests"
              name="HR Review Requests"
              parent="menu_recruitment_request_root"
              action="action_hr_review_requests"
              sequence="2"/>

    <record id="action_ceo_approval_requests" model="ir.actions.act_window">
        <field name="name">CEO Approval Requests</field>
        <field name="res_model">recruitment.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['sent_ceo', 'approved', 'rejected'])]</field>
    </record>

    <menuitem id="menu_ceo_approval_requests"
              name="CEO Approval Requests"
              parent="menu_recruitment_request_root"
              action="action_ceo_approval_requests"
              sequence="3"/>

</odoo>