<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_recruitment_stage_view_form_overdue" model="ir.ui.view">
        <field name="name">hr.recruitment.stage.form.overdue</field>
        <field name="model">hr.recruitment.stage</field>
        <field name="inherit_id" ref="hr_recruitment.hr_recruitment_stage_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='fold']" position="after">
                <field name="overdue_limit_days"/>
            </xpath>

        </field>
    </record>

    <record id="hr_recruitment_stage_view_tree_overdue" model="ir.ui.view">
        <field name="name">hr.recruitment.stage.list.overdue</field>
        <field name="model">hr.recruitment.stage</field>
        <field name="inherit_id" ref="hr_recruitment.hr_recruitment_stage_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='name']" position="after">
                <field name="overdue_limit_days"/>
            </xpath>

        </field>
    </record>

</odoo>