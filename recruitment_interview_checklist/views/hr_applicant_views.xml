<odoo>

    <!-- ========================================================= -->
    <!-- Standalone Tree View for Interview Evaluation              -->
    <!-- ========================================================= -->
    <record id="view_applicant_interview_evaluation_tree" model="ir.ui.view">
        <field name="name">applicant.interview.evaluation.tree</field>
        <field name="model">applicant.interview.evaluation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="applicant_id"/>
                <field name="stage_id"/>
                <field name="evaluator_id"/>
                <field name="total_score"/>
                <field name="average_score"/>
                <field name="note"/>
            </tree>
        </field>
    </record>


    <!-- ========================================================= -->
    <!-- Standalone Form View for Interview Evaluation              -->
    <!-- ========================================================= -->
    <record id="view_applicant_interview_evaluation_form" model="ir.ui.view">
        <field name="name">applicant.interview.evaluation.form</field>
        <field name="model">applicant.interview.evaluation</field>
        <field name="arch" type="xml">
            <form string="Interview Evaluation">
                <sheet>
                    <group>
                        <group>
                            <field name="applicant_id" readonly="1"/>
                            <field name="stage_id" readonly="1"/>
                            <field name="evaluator_id"/>
                        </group>

                        <group>
                            <field name="total_score" readonly="1"/>
                            <field name="average_score" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Checklist Scoring">
                            <field name="line_ids">
                                <tree editable="bottom" create="true" delete="true">
                                    <field name="criteria"/>
                                    <field name="max_score"/>
                                    <field name="score"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Overall Comment">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>

                <footer>
                    <button string="Save"
                            special="save"
                            class="btn-primary"/>

                    <button string="Discard"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


    <!-- ========================================================= -->
    <!-- Candidate Ranking Tree View                               -->
    <!-- ========================================================= -->
    <record id="view_hr_applicant_candidate_ranking_tree" model="ir.ui.view">
        <field name="name">hr.applicant.candidate.ranking.tree</field>
        <field name="model">hr.applicant</field>
        <field name="arch" type="xml">
            <tree string="Candidate Ranking"
                  default_order="interview_average_score desc"
                  decoration-success="interview_average_score &gt;= 8"
                  decoration-warning="interview_average_score &gt;= 6 and interview_average_score &lt; 8"
                  decoration-danger="interview_average_score &lt; 6">

                <field name="partner_name" string="Candidate"/>
                <field name="job_id" string="Applied Job"/>
                <field name="stage_id" string="Recruitment Stage"/>
                <field name="evaluation_count" string="Evaluation Count"/>
                <field name="interview_average_score" string="Average Score"/>
                <field name="interview_total_score" string="Total Score"/>

            </tree>
        </field>
    </record>


    <!-- ========================================================= -->
    <!-- Candidate Ranking Search View                             -->
    <!-- ========================================================= -->
    <record id="view_hr_applicant_candidate_ranking_search" model="ir.ui.view">
        <field name="name">hr.applicant.candidate.ranking.search</field>
        <field name="model">hr.applicant</field>
        <field name="arch" type="xml">
            <search string="Candidate Ranking">

                <!-- Search trực tiếp theo tên ứng viên, vị trí tuyển dụng, vòng tuyển dụng -->
                <field name="partner_name" string="Candidate"/>
                <field name="job_id" string="Applied Job"/>
                <field name="stage_id" string="Recruitment Stage"/>

                <!-- Filter ứng viên đã có đánh giá -->
                <filter name="has_evaluation"
                        string="Has Evaluation"
                        domain="[('evaluation_count', '&gt;', 0)]"/>

                <separator string="Score Range"/>

                <!-- Lọc theo thang điểm 1 - 10 -->
                <filter name="score_9_10"
                        string="Score 9 - 10"
                        domain="[('interview_average_score', '&gt;=', 9), ('interview_average_score', '&lt;=', 10)]"/>

                <filter name="score_8_9"
                        string="Score 8 - below 9"
                        domain="[('interview_average_score', '&gt;=', 8), ('interview_average_score', '&lt;', 9)]"/>

                <filter name="score_7_8"
                        string="Score 7 - below 8"
                        domain="[('interview_average_score', '&gt;=', 7), ('interview_average_score', '&lt;', 8)]"/>

                <filter name="score_6_7"
                        string="Score 6 - below 7"
                        domain="[('interview_average_score', '&gt;=', 6), ('interview_average_score', '&lt;', 7)]"/>

                <filter name="score_5_6"
                        string="Score 5 - below 6"
                        domain="[('interview_average_score', '&gt;=', 5), ('interview_average_score', '&lt;', 6)]"/>

                <filter name="score_4_5"
                        string="Score 4 - below 5"
                        domain="[('interview_average_score', '&gt;=', 4), ('interview_average_score', '&lt;', 5)]"/>

                <filter name="score_3_4"
                        string="Score 3 - below 4"
                        domain="[('interview_average_score', '&gt;=', 3), ('interview_average_score', '&lt;', 4)]"/>

                <filter name="score_2_3"
                        string="Score 2 - below 3"
                        domain="[('interview_average_score', '&gt;=', 2), ('interview_average_score', '&lt;', 3)]"/>

                <filter name="score_1_2"
                        string="Score 1 - below 2"
                        domain="[('interview_average_score', '&gt;=', 1), ('interview_average_score', '&lt;', 2)]"/>

                <!-- Group By để gom nhóm dữ liệu -->
                <group expand="0" string="Group By">
                    <filter name="group_by_job"
                            string="Applied Job"
                            context="{'group_by': 'job_id'}"/>

                    <filter name="group_by_stage"
                            string="Recruitment Stage"
                            context="{'group_by': 'stage_id'}"/>
                </group>

                <!-- Search Panel để chọn giá trị cụ thể -->
                <searchpanel>
                    <field name="job_id"
                           string="Applied Job"
                           select="multi"
                           enable_counters="1"/>

                    <field name="stage_id"
                           string="Recruitment Stage"
                           select="multi"
                           enable_counters="1"/>
                </searchpanel>

            </search>
        </field>
    </record>


    <!-- ========================================================= -->
    <!-- Candidate Ranking Action                                  -->
    <!-- ========================================================= -->
    <record id="action_candidate_ranking" model="ir.actions.act_window">
        <field name="name">Candidate Ranking</field>
        <field name="res_model">hr.applicant</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_hr_applicant_candidate_ranking_tree"/>
        <field name="search_view_id" ref="view_hr_applicant_candidate_ranking_search"/>
        <field name="domain">[('evaluation_count', '&gt;', 0)]</field>
        <field name="context">{}</field>
    </record>


    <!-- ========================================================= -->
    <!-- Candidate Ranking Menu                                    -->
    <!-- ========================================================= -->
    <menuitem id="menu_interview_evaluation_root"
              name="Interview Evaluation"
              parent="hr_recruitment.menu_hr_recruitment_root"
              sequence="55"/>

    <menuitem id="menu_candidate_ranking"
              name="Candidate Ranking"
              parent="menu_interview_evaluation_root"
              action="action_candidate_ranking"
              sequence="10"/>


    <!-- ========================================================= -->
    <!-- Inherit Applicant Form                                    -->
    <!-- ========================================================= -->
    <record id="view_hr_applicant_form_interview_evaluation" model="ir.ui.view">
        <field name="name">hr.applicant.form.interview.evaluation</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Interview Evaluation">

                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div>
                            <h3 class="mb-1">Interview Evaluation</h3>
                            <span class="text-muted">
                                The checklist is automatically loaded based on the applicant's current interview stage.
                            </span>
                        </div>

                        <button name="action_create_interview_evaluation"
                                type="object"
                                string="New Evaluation"
                                class="btn btn-primary"/>
                    </div>

                    <group>
                        <group string="Evaluation Summary">
                            <field name="interview_total_score" readonly="1"/>
                            <field name="interview_average_score" readonly="1"/>
                            <field name="evaluation_count" readonly="1"/>
                        </group>
                    </group>

                    <field name="evaluation_ids">
                        <tree create="false" edit="false" delete="true">
                            <field name="stage_id"/>
                            <field name="evaluator_id"/>
                            <field name="total_score"/>
                            <field name="average_score"/>
                            <field name="note"/>

                            <button name="action_open_evaluation"
                                    type="object"
                                    string="Open"
                                    class="btn-link"/>
                        </tree>
                    </field>

                </page>
            </xpath>

            <xpath expr="//field[@name='partner_name']" position="after">
                <field name="interview_average_score" readonly="1"/>
            </xpath>

        </field>
    </record>

</odoo>