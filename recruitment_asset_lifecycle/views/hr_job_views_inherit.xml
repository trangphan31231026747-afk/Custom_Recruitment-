<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_job_form_inherit_asset" model="ir.ui.view">
        <field name="name">hr.job.form.inherit.asset</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='recruitment']" position="after">
                <group string="Cấu hình Tài sản Onboarding" name="asset_config">
                    <field name="asset_package_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>