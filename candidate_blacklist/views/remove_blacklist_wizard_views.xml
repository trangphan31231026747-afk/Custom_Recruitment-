<odoo>
    <record id="view_remove_blacklist_wizard_form" model="ir.ui.view">
        <field name="name">recruitment.remove.blacklist.wizard.form</field>
        <field name="model">recruitment.remove.blacklist.wizard</field>
        <field name="arch" type="xml">
            <form string="Remove Blacklist">
                <group>
                    <field name="blacklist_id"/>
                    <field name="remove_reason" placeholder="Enter the reason for removing this blacklist record..."/>
                </group>

                <footer>
                    <button name="action_confirm_remove_blacklist"
                            string="Confirm Remove"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>