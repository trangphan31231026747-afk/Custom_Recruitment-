<odoo>
    <record id="view_interview_checklist_template_tree" model="ir.ui.view">
        <field name="name">interview.checklist.template.tree</field>
        <field name="model">interview.checklist.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="stage_id"/>
            </tree>
        </field>
    </record>

    <record id="view_interview_checklist_template_form" model="ir.ui.view">
        <field name="name">interview.checklist.template.form</field>
        <field name="model">interview.checklist.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="stage_id"/>
                    </group>

                    <notebook>
                        <page string="Checklist Criteria">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="max_score"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_interview_checklist_template" model="ir.actions.act_window">
        <field name="name">Interview Checklist Templates</field>
        <field name="res_model">interview.checklist.template</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Đưa Interview Checklist vào Configuration của Recruitment -->
    <menuitem id="menu_interview_checklist_root"
              name="Interview Checklist"
              parent="hr_recruitment.menu_hr_recruitment_configuration"
              sequence="80"/>

    <menuitem id="menu_interview_checklist_template"
              name="Checklist Templates"
              parent="menu_interview_checklist_root"
              action="action_interview_checklist_template"
              sequence="10"/>
</odoo>